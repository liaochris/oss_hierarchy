Import('*')

from source.lib.python.config_loaders import LoadPipelineInputs

_cfg = LoadPipelineInputs("../../../source/lib/config/pipeline_inputs.json")
IMPORTANCE_TYPES     = _cfg["importance_types"]["run"]
ROLLING_PERIODS      = [f"rolling{p}" for p in _cfg["rolling_periods"]["run"]]
QUALIFIED_SAMPLES    = _cfg["qualified_samples"]["run"]
CONTROL_GROUPS       = _cfg["control_groups"]["run"]
OUTPUT_FILES         = [
    "panel.parquet", "panel.log",
    "pc_score_metadata.csv", "pc_score_metadata.log",
    "pc_score_excluded_vars.csv", "pc_score_excluded_vars.log",
    "pc_score_columns.json",
]

helper_sources = [
    '#source/derived/analysis_panel/prepare_panel.py',
    '#source/lib/config/analysis_parameters.json',
    '#source/lib/config/outcome_variables.json',
    '#source/lib/config/pipeline_inputs.json',
    '#source/lib/config/paper_settings.json',
    '#source/lib/pc_groups.json',
]

for importance_type in IMPORTANCE_TYPES:
    for rolling_period in ROLLING_PERIODS:
        panel_source = f'#drive/output/derived/org_outcomes_practices/org_panel/{importance_type}/{rolling_period}/panel.parquet'
        call_sources = helper_sources + [panel_source]

        call_targets = []
        for qualified_sample in QUALIFIED_SAMPLES:
            for control_group in CONTROL_GROUPS:
                base = f'#output/derived/analysis_panel/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}'
                call_targets.extend(f'{base}/{f}' for f in OUTPUT_FILES)

        if importance_type == IMPORTANCE_TYPES[0] and rolling_period == ROLLING_PERIODS[0]:
            _pc_groups = ["collaboration", "shared_knowledge", "discussion_quality",
                          "investment_in_new_talent", "problem_solving_routines"]
            call_targets += (
                ['#output/autofill/panel_autofill.tex', '#output/autofill/pc_autofill.tex']
                + [f'#output/derived/analysis_panel/pc_loadings_{g}.txt' for g in _pc_groups]
            )

        env.Python(call_targets, call_sources,
                   CL_ARG=[f'CL_IMPORTANCE_TYPE={importance_type}', f'CL_ROLLING_PERIOD={rolling_period}'])
