Import('*')

from source.lib.python.config_loaders import LoadPipelineInputs

_cfg = LoadPipelineInputs("../../../source/lib/config/pipeline_inputs.json")
IMPORTANCE_TYPES  = _cfg["importance_types"]["run"]
ROLLING_PERIODS   = [f"rolling{p}" for p in _cfg["rolling_periods"]["run"]]
QUALIFIED_SAMPLES = _cfg["qualified_samples"]["run"]
CONTROL_GROUPS    = _cfg["control_groups"]["run"]
FOREST_OUTCOME    = _cfg["forest_training_outcome"]

INDIR_PREP   = "#output/analysis/data_prep"
INDIR_FOREST = "#output/analysis/event_study_forest"
OUTDIR       = "#output/analysis/analyze_forest"
COVAR_TYPE   = "pc_score"

AGGREGATED_SAMPLES     = {"exact_1_2": ["exact1", "exact2"]}
NON_AGGREGATED_SAMPLES = [s for s in QUALIFIED_SAMPLES if s not in AGGREGATED_SAMPLES]

SHARED_LIBS = [
    "#source/analysis/analyze_forest/helpers.R",
    "#source/lib/R/config_loaders.R",
    "#source/lib/R/analysis_utils.R",
    "#source/lib/R/constants.R",
    "#source/lib/R/forest_helpers.R",
    "#source/lib/config/pipeline_inputs.json",
    "#source/lib/config/feature_variables.json",
    "#source/lib/config/outcome_variables.json",
    "#source/lib/config/analysis_parameters.json",
    "#source/lib/config/plotting.json",
]

def forest_parquet(imp, roll, samp, ctrl):
    return f"{INDIR_FOREST}/{imp}/{roll}/{samp}/{ctrl}/{COVAR_TYPE}/{FOREST_OUTCOME}_repo_att_event_study_forest.parquet"

def panel_parquet(imp, roll, samp, ctrl):
    return f"{INDIR_PREP}/{imp}/{roll}/{samp}/{ctrl}/panel_with_pc_scores.parquet"

def outbase(imp, roll, samp, ctrl):
    return f"{OUTDIR}/{imp}/{roll}/{samp}/{ctrl}"

def all_combos(samples=None):
    samples = samples or QUALIFIED_SAMPLES
    return [
        (imp, roll, samp, ctrl)
        for imp  in IMPORTANCE_TYPES
        for roll in ROLLING_PERIODS
        for samp in samples
        for ctrl in CONTROL_GROUPS
    ]

def run_r(script, targets, inputs):
    env.R(targets, [f"#source/analysis/analyze_forest/{script}"] + SHARED_LIBS + inputs)

all_forest_inputs = list(dict.fromkeys(
    forest_parquet(imp, roll, sub, ctrl)
    for imp, roll, samp, ctrl in all_combos()
    for sub in AGGREGATED_SAMPLES.get(samp, [samp])
))

all_panel_inputs = [
    panel_parquet(imp, roll, samp, ctrl)
    for imp, roll, samp, ctrl in all_combos(NON_AGGREGATED_SAMPLES)
]

run_r("pc_correlation_heatmap.R",
      [f"{outbase(*c)}/heatmap_corr.png" for c in all_combos()],
      all_forest_inputs)

run_r("pc_score_combinations.R",
      [f"{outbase(*c)}/{fname}" for c in all_combos()
       for fname in ["pc_score_combo.png", "pc_score_combo_gradient.png",
                     "pc_score_combo_k2_table.csv", "pc_score_combo_k2_high_table.csv",
                     "pc_score_combo_k3_table.csv", "pc_score_combo_k3_high_table.csv"]],
      all_forest_inputs)

run_r("fold_comparisons.R",
      [f"{outbase(*c)}/{fname}" for c in all_combos(list(AGGREGATED_SAMPLES))
       for fname in ["cross_forest_grid.png", "fold_corr_att.png",
                     "fold_corr_rank.png", "variable_importance.tex"]],
      all_forest_inputs)

run_r("outcome_diagnostics.R",
      [f"{outbase(*c)}/outcome_summary_table.tex" for c in all_combos()],
      all_forest_inputs + all_panel_inputs)

run_r("org_timeline.R",
      [f"{outbase(*c)}/hist_org_count.png" for c in all_combos()],
      all_forest_inputs + all_panel_inputs)
