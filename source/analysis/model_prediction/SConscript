Import('*')

from itertools import product
from source.lib.python.config_loaders import LoadGlobalSettings, LoadPipelineInputs
from source.lib.python.repo_utils import MakeRepoNameSafe

_g   = LoadGlobalSettings("../../../source/lib/config/global_settings.json")
_cfg = LoadPipelineInputs("../../../source/lib/config/pipeline_inputs.json")

ref               = MakeRepoNameSafe(_g["reference_github_repo"])
importance_types  = _cfg["importance_types"]["run"]
rolling_periods   = [f"rolling{p}" for p in _cfg["rolling_periods"]["run"]]
qualified_samples = _cfg["qualified_samples"]["run"]
control_groups    = _cfg["control_groups"]["run"]

combos     = list(product(importance_types, rolling_periods, qualified_samples, control_groups))
combos_iqc = list(product(importance_types, qualified_samples, control_groups))

helpers_deps = [
    '#source/analysis/model_prediction/helpers.py',
    '#source/lib/python/config_loaders.py',
    '#source/lib/python/repo_utils.py',
    '#source/lib/JMSLab/SaveData.py',
    '#source/lib/config/pipeline_inputs.json',
    '#source/lib/config/analysis_parameters.json',
]

member_panel_sentinels = [
    f'#drive/output/derived/model_prediction/event_time_member_panel/{importance_type}/{qualified_sample}/{control_group}/{ref}.parquet'
    for importance_type, qualified_sample, control_group in combos_iqc
]

panel_sources = [
    f'#output/analysis/data_prep/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}/panel.parquet'
    for importance_type, rolling_period, qualified_sample, control_group in combos
]

problem_flow_targets = []
problem_flow_data    = []
for importance_type, rolling_period, qualified_sample, control_group in combos:
    base = f'#drive/output/analysis/model_prediction/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}'
    problem_flow_targets += [
        f'{base}/problem_flow_selection.parquet',
        f'{base}/problem_flow_selection.log',
        f'#output/analysis/model_prediction/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}/tables/problem_flow_selection.tex',
        f'#output/analysis/model_prediction/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}/recommended_config.json',
    ]
    problem_flow_data.append(f'{base}/problem_flow_selection.parquet')

problem_flow_plot_targets = [
    f'#output/analysis/model_prediction/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}/plots/problem_flow_fan.png'
    for importance_type, rolling_period, qualified_sample, control_group in combos
] + [
    f'#output/analysis/model_prediction/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}/plots/problem_flow_error_dist.png'
    for importance_type, rolling_period, qualified_sample, control_group in combos
] + [
    f'#output/analysis/model_prediction/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}/plots/problem_flow_error_by_k.png'
    for importance_type, rolling_period, qualified_sample, control_group in combos
]

env.Python(
    problem_flow_targets,
    helpers_deps + [
        '#source/analysis/model_prediction/fit_problem_flow.py',
    ] + panel_sources + member_panel_sentinels,
)

env.Python(
    problem_flow_plot_targets,
    helpers_deps + [
        '#source/analysis/model_prediction/plot_problem_flow.py',
    ] + problem_flow_data,
)
