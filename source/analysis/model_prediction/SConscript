Import('*')

from itertools import product
from source.lib.python.config_loaders import LoadPipelineInputs, LoadAnalysisParameters, LoadGlobals
from source.lib.python.repo_utils import MakeRepoNameSafe

_cfg = LoadPipelineInputs("../../../source/lib/config/pipeline_inputs.json")
_ap  = LoadAnalysisParameters("../../../source/lib/config/analysis_parameters.json")
_model_prediction_config = LoadGlobals("../../../source/lib/config/model_prediction.json")

ref_by_sample         = {qs: MakeRepoNameSafe(r) for qs, r in _ap["model_reference_repos"].items()}
importance_types      = _cfg["importance_types"]["run"]
rolling_label         = f"rolling{_cfg['rolling_periods']['run'][0]}"
qualified_samples     = [s for s in _cfg["qualified_samples"]["run"] if s in {"exact1", "exact2", "exact_1_2"}]
control_groups        = _cfg["control_groups"]["run"]
variants              = _model_prediction_config["variants"]["run"]
estimation_approaches = _model_prediction_config["member_probability_estimation"]["run"]
run_error_metrics     = _model_prediction_config["error_metrics"]["run"]
post_times            = list(range(1, _ap["max_event_time"] + 1))
eval_keys             = [str(t) for t in post_times] + ["1_5"]

combos = list(product(importance_types, qualified_samples, control_groups))

shared_deps = [
    '#source/lib/python/config_loaders.py',
    '#source/lib/python/repo_utils.py',
    '#source/lib/JMSLab/SaveData.py',
    '#source/lib/config/pipeline_inputs.json',
]
panel_sources = [
    f'#output/derived/analysis_panel/{imp}/{rolling_label}/{qs}/{cg}/panel.parquet'
    for imp, qs, cg in combos
]
member_panel_sources = [
    f'#drive/output/derived/model_prediction/event_time_member_panel/{variant}/{imp}/{qs}/{cg}/{ref_by_sample[qs]}.parquet'
    for variant, (imp, qs, cg) in product(variants, combos)
]

fit_targets = []
for variant, (imp, qs, cg), estimation_approach in product(variants, combos, estimation_approaches):
    base = f'#output/analysis/model_prediction/{variant}/fitted/{estimation_approach}/{imp}/{qs}/{cg}'
    fit_targets += [
        f'{base}/distribution_params.parquet',
        f'{base}/distribution_params.log',
        f'{base}/distribution_comparison.parquet',
        f'{base}/distribution_comparison.log',
        f'{base}/member_probabilities.parquet',
        f'{base}/member_probabilities.log',
        f'{base}/review_fit_check.parquet',
        f'{base}/review_fit_check.log',
    ]

env.Python(
    fit_targets,
    ['#source/analysis/model_prediction/fit_model.py',
     '#source/lib/config/model_prediction.json']
    + shared_deps + panel_sources + member_panel_sources,
)

predict_targets = []
for variant, (imp, qs, cg), t, estimation_approach in product(variants, combos, post_times, estimation_approaches):
    base = f'#output/analysis/model_prediction/{variant}/predictions/{estimation_approach}/{imp}/{qs}/{cg}/event_time_{t}'
    predict_targets += [
        f'{base}/predictions.parquet',
        f'{base}/predictions.log',
    ]

pre_period_targets = []
for variant, (importance_type, qualified_sample, control_group), estimation_approach in product(
    variants, combos, estimation_approaches
):
    base = (
        f'#output/analysis/model_prediction/{variant}/pre_period'
        f'/{estimation_approach}/{importance_type}/{qualified_sample}/{control_group}'
    )
    pre_period_targets += [
        f'{base}/pre_period_evaluation.parquet',
        f'{base}/pre_period_evaluation.log',
    ]

env.Python(
    predict_targets + pre_period_targets,
    ['#source/analysis/model_prediction/predict_model.py',
     '#source/lib/config/model_prediction.json']
    + shared_deps + fit_targets + panel_sources + member_panel_sources,
)

evaluation_outcomes = ["open", "review_rate", "merge_rate"]

evaluate_targets = []
for variant, (imp, qs, cg), estimation_approach, key, group in product(
    variants, combos, estimation_approaches, eval_keys, ['treated', 'control']
):
    base = f'#output/analysis/model_prediction/{variant}/evaluation/{estimation_approach}/{imp}/{qs}/{cg}/event_time_{key}/{group}'
    evaluate_targets += [
        f'{base}/{metric}_{outcome}.png'
        for metric in run_error_metrics
        for outcome in evaluation_outcomes
    ] + [f'{base}/prediction_error_summary.csv']

summary_targets = [
    f'#output/analysis/model_prediction/{variant}/evaluation/{estimation_approach}/{imp}/{qs}/{cg}/prediction_error_summary_all.csv'
    for variant, (imp, qs, cg), estimation_approach in product(variants, combos, estimation_approaches)
]

pre_period_evaluation_targets = []
for variant, (importance_type, qualified_sample, control_group), estimation_approach in product(
    variants, combos, estimation_approaches
):
    base = (
        f'#output/analysis/model_prediction/{variant}/pre_period'
        f'/{estimation_approach}/{importance_type}/{qualified_sample}/{control_group}'
    )
    pre_period_evaluation_targets += [
        f'{base}/{group}/{metric}_{outcome}.png'
        for group in ['treated', 'control']
        for metric in run_error_metrics
        for outcome in evaluation_outcomes
    ]

env.Python(
    evaluate_targets + summary_targets + pre_period_evaluation_targets,
    ['#source/analysis/model_prediction/evaluate_predictions.py',
     '#source/lib/config/pipeline_inputs.json',
     '#source/lib/config/analysis_parameters.json',
     '#source/lib/config/model_prediction.json']
    + predict_targets + pre_period_targets,
)
