Import('*')

import json
from source.lib.helpers import LoadOutcomeVariables, LoadPipelineInputs

_cfg = LoadPipelineInputs("../../../source/lib/project_config.json")
IMPORTANCE_TYPES  = _cfg["importance_types"]["run"]
ROLLING_PERIODS   = [f"rolling{p}" for p in _cfg["rolling_periods"]["run"]]
QUALIFIED_SAMPLES = _cfg["qualified_samples"]["run"]
CONTROL_GROUPS    = _cfg["control_groups"]["run"]

_outcomes_cfg = LoadOutcomeVariables("../../../source/lib/project_config.json")
with open("../../../source/analysis/config/pc_groups.json") as fh:
    _pc_groups_cfg = json.load(fh)

OUTCOMES = [outcome for category_cfg in _outcomes_cfg.values() for outcome in category_cfg.get("run", [])]
CATEGORIES = {
    outcome: category
    for category, category_cfg in _outcomes_cfg.items()
    for outcome in category_cfg.get("run", [])
}
PCA_GROUPS = list(_pc_groups_cfg.keys())

OUTDIR    = "#output/analysis/event_study"
INDIR_PREP = "#output/analysis/data_prep"

sources = [
    "#source/analysis/event_study/estimate_resilience.R",
    "#source/lib/event_study_helpers.R",
    "#source/lib/constants.R",
    "#source/lib/helpers.R",
    "#source/lib/project_config.json",
    "#source/analysis/config/pc_groups.json",
]
for importance_type in IMPORTANCE_TYPES:
    for rolling_period in ROLLING_PERIODS:
        for qualified_sample in QUALIFIED_SAMPLES:
            for control_group in CONTROL_GROUPS:
                base = f"{INDIR_PREP}/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}"
                sources += [f"{base}/panel.parquet", f"{base}/panel_PCA_median.parquet"]

targets = [
    f"{OUTDIR}/all_estimates.csv",
    f"{OUTDIR}/all_estimates.log",
]
for importance_type in IMPORTANCE_TYPES:
    for rolling_period in ROLLING_PERIODS:
        for qualified_sample in QUALIFIED_SAMPLES:
            for control_group in CONTROL_GROUPS:
                base = f"{OUTDIR}/{importance_type}/{rolling_period}/{qualified_sample}/{control_group}"
                for outcome in OUTCOMES:
                    targets.append(f"{base}/full_sample/{CATEGORIES[outcome]}/{outcome}.png")
                for pc_group_name in PCA_GROUPS:
                    for outcome in OUTCOMES:
                        targets.append(f"{base}/PCA/{CATEGORIES[outcome]}/{pc_group_name}_{outcome}_principal_component1_split.png")

env.R(targets, sources)
